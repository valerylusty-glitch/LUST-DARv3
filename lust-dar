#!/data/data/com.termux/files/usr/bin/bash

# COLORS
GREEN='\033[1;32m'
RED='\033[1;31m'
BLUE='\033[1;34m'
PURPLE='\033[1;35m'
CYAN='\033[1;36m'
YELLOW='\033[1;33m'
WHITE='\033[1;37m'
NC='\033[0m'

banner() {
clear
echo -e "${RED}"
echo "‚Ėą‚Ėą‚ēó     ‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó"
echo "‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ"
echo -e "${PURPLE}"
echo "‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēĎ"
echo "‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ"
echo -e "${BLUE}"
echo "‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ"
echo "‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ"

echo ""
echo -e "${CYAN}        LUST DAR V3"
echo -e "${YELLOW}      SECURITY TERMINAL"
echo -e "${GREEN}        POWERED BY LUST DEV"
echo -e "${WHITE}‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ${NC}"
}

pause() {
read -p "PRESS ENTER TO CONTINUE..."
}

system_info() {
banner
echo -e "${GREEN}[ SYSTEM INFORMATION ]${NC}"
uname -a
echo
df -h
echo
free -h 2>/dev/null || echo "MEMORY INFO NOT AVAILABLE"
pause
}

network_info() {
banner
echo -e "${BLUE}[ NETWORK INFORMATION ]${NC}"
ip addr
echo
ip route
pause
}

public_ip() {
banner
echo -e "${CYAN}[ PUBLIC IP ]${NC}"
curl -s https://api.ipify.org
echo
pause
}

ping_test() {
banner
echo -e "${YELLOW}[ CONNECTION TEST ]${NC}"
read -p "HOST OR IP: " host
ping -c 4 "$host"
pause
}

dns_lookup() {
banner
echo -e "${PURPLE}[ DNS LOOKUP ]${NC}"
read -p "DOMAIN: " domain
nslookup "$domain"
pause
}

file_hash() {
banner
echo -e "${GREEN}[ SHA256 HASH CHECK ]${NC}"
read -p "FILE PATH: " file
sha256sum "$file"
pause
}

process_view() {
banner
echo -e "${RED}[ RUNNING PROCESSES ]${NC}"
ps -A
pause
}

while true
do
banner

echo -e "${GREEN}[01] SYSTEM INFORMATION"
echo -e "${BLUE}[02] NETWORK INFORMATION"
echo -e "${CYAN}[03] PUBLIC IP CHECK"
echo -e "${YELLOW}[04] CONNECTION TEST"
echo -e "${PURPLE}[05] DNS LOOKUP"
echo -e "${WHITE}[06] FILE HASH CHECK"
echo -e "${RED}[07] RUNNING PROCESSES"
echo -e "${GREEN}[00] EXIT${NC}"

echo
read -p "LUST@DAR ‚ěú " choice

case $choice in
01|1) system_info ;;
02|2) network_info ;;
03|3) public_ip ;;
04|4) ping_test ;;
05|5) dns_lookup ;;
06|6) file_hash ;;
07|7) process_view ;;
00|0)
clear
echo -e "${RED}SHUTTING DOWN LUST DAR...${NC}"
sleep 1
exit
;;
*)
echo -e "${RED}INVALID OPTION${NC}"
sleep 1
;;
esac

done
